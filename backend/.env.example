# ── Copy this to .env and fill in real values ────────────────────────────────

# General
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string

# CORS – add your Vercel frontend URL
CORS_ORIGINS=["https://vietnamese-traditional-instrument-a.vercel.app","http://localhost:3001"]

# OpenAI
OPENAI_API_KEY=sk-...

# MongoDB (override if using an external Atlas cluster)
MONGODB_URI=mongodb://mongo:27017/
MONGODB_DB_NAME=instrument_detection_db

# LLM
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512

# Embedding model (downloads on first run from HuggingFace Hub)
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# Paths inside the container (leave as-is unless you change the Dockerfile)
# MODEL_DIR=/app/models
# STATIC_DIR=/app/static
